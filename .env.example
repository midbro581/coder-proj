# Coder — example environment file
# Copy this file to ".env" (no .example) and edit DB_PASSWORD if needed.
# The default XAMPP MySQL root user has NO password — leave it blank.

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=coder_db
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
PORT=3001
